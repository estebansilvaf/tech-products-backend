# Copia este archivo a .env y ajusta los valores.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# Puerto HTTP (opcional; por defecto 3000)
PORT=3000

# development = respuestas 500 con detalle (pgCode, message). En producción usa production.
# NODE_ENV=development

# --- Conexión PostgreSQL ---
# Usa UNA de las dos formas siguientes.

# Opción A — URL única (útil en Docker, Railway, Render, etc.)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/tech_products

# Opción B — variables separadas (cómodo en desarrollo local)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=tu_contraseña
PGDATABASE=tech_products
